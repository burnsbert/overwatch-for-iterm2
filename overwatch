#!/usr/bin/env python3
"""Overwatch — a live dashboard for your iTerm2 tabs.

Shows current directory and session name for every tab, highlights
Claude Code sessions, and lets you navigate, switch to, or close tabs
without leaving the terminal.

Requires macOS and iTerm2. No dependencies beyond Python 3.7+ stdlib.
"""

import curses
import json
import os
import pathlib
import re
import subprocess
import time
import urllib.error
import urllib.request
from datetime import datetime, timedelta, timezone

APPLESCRIPT = '''
tell application "iTerm2"
    set output to ""
    repeat with w from 1 to (count of windows)
        tell window w
            set tabCount to count of tabs
            repeat with t from 1 to tabCount
                tell tab t
                    tell current session
                        set sName to name
                        set varPath to variable named "path"
                        set sTty to tty
                        set output to output & w & "\t" & t & "\t" & varPath & "\t" & sName & "\t" & sTty & "\n"
                    end tell
                end tell
            end repeat
        end tell
    end repeat
    return output
end tell
'''

CLOSE_TAB_APPLESCRIPT = '''
tell application "iTerm2"
    tell window {win}
        tell tab {tab}
            close
        end tell
    end tell
end tell
'''

GOTO_TAB_APPLESCRIPT = '''
tell application "iTerm2"
    tell current window
        select tab {tab}
    end tell
    activate
end tell
'''

NEW_TAB_APPLESCRIPT = '''
tell application "iTerm2"
    tell current window
        create tab with default profile
    end tell
    activate
end tell
'''

REFRESH_INTERVAL = 10
USAGE_REFRESH_INTERVAL = 240

MY_TTY = os.ttyname(0) if os.isatty(0) else ''
HOME = str(pathlib.Path.home())


def get_claude_ttys():
    """Find TTYs that have a 'claude' process running on them."""
    try:
        result = subprocess.run(
            ['ps', '-eo', 'tty,comm'],
            capture_output=True, text=True, timeout=3
        )
        ttys = set()
        for line in result.stdout.strip().split('\n'):
            parts = line.split(None, 1)
            if len(parts) == 2:
                tty, comm = parts
                if 'claude' in comm.lower():
                    ttys.add(f'/dev/{tty}')
        return ttys
    except Exception:
        return set()


def fetch_tabs():
    try:
        result = subprocess.run(
            ['osascript', '-e', APPLESCRIPT],
            capture_output=True, text=True, timeout=5
        )
        lines = []
        for line in result.stdout.strip().split('\n'):
            if not line:
                continue
            parts = line.split('\t', 4)
            if len(parts) == 5:
                # AppleScript returns "missing value" for unset properties
                cleaned = ['' if p == 'missing value' else p for p in parts]
                lines.append((cleaned[0], cleaned[1], cleaned[2], cleaned[3], cleaned[4]))
        return lines
    except Exception as e:
        return [('1', '?', f'Error: {e}', '', '')]


def fill_missing_paths(tabs):
    """Use lsof to detect working directories when shell integration is unavailable."""
    empty_ttys = {tty for _, _, path, _, tty in tabs if not path and tty}
    if not empty_ttys:
        return tabs
    try:
        # Find first (oldest = shell) PID per TTY
        result = subprocess.run(
            ['ps', '-eo', 'pid,tty'], capture_output=True, text=True, timeout=3
        )
        tty_pid = {}
        for line in result.stdout.strip().split('\n')[1:]:
            parts = line.split()
            if len(parts) >= 2:
                tty = f'/dev/{parts[1]}'
                if tty in empty_ttys:
                    tty_pid[tty] = parts[0]  # last (highest) PID = shell, not login
        if not tty_pid:
            return tabs
        # Batch lsof for CWDs
        result = subprocess.run(
            ['lsof', '-a', '-d', 'cwd', '-p', ','.join(tty_pid.values()), '-Fn'],
            capture_output=True, text=True, timeout=3
        )
        pid_cwd = {}
        cur_pid = None
        for line in result.stdout.split('\n'):
            if line.startswith('p'):
                cur_pid = line[1:]
            elif line.startswith('n') and cur_pid:
                pid_cwd[cur_pid] = line[1:]
        tty_cwd = {tty: pid_cwd.get(pid, '') for tty, pid in tty_pid.items()}
        return [(w, t, tty_cwd.get(tty, path) if not path else path, n, tty)
                for w, t, path, n, tty in tabs]
    except Exception:
        return tabs


def new_tab():
    subprocess.run(['osascript', '-e', NEW_TAB_APPLESCRIPT], capture_output=True, timeout=5)


def close_tab(win_num, tab_num):
    script = CLOSE_TAB_APPLESCRIPT.format(win=win_num, tab=tab_num)
    subprocess.run(['osascript', '-e', script], capture_output=True, timeout=5)


def goto_tab(win_num, tab_num):
    script = GOTO_TAB_APPLESCRIPT.format(win=win_num, tab=tab_num)
    subprocess.run(['osascript', '-e', script], capture_output=True, timeout=5)


def shorten_path(path):
    if path.startswith(HOME):
        return '~' + path[len(HOME):]
    return path


def get_oauth_token():
    """Retrieve Claude Code OAuth token from macOS Keychain."""
    try:
        result = subprocess.run(
            ['security', 'find-generic-password',
             '-s', 'Claude Code-credentials', '-w'],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode != 0:
            return None
        creds = json.loads(result.stdout.strip())
        return creds.get('claudeAiOauth', {}).get('accessToken')
    except Exception:
        return None


def fetch_usage():
    """Fetch usage data from the Claude Code API. Returns (dict, retry_after) or (None, retry_after).

    retry_after is seconds to wait before retrying (from Retry-After header), or None.
    """
    token = get_oauth_token()
    if not token:
        return None, None
    try:
        req = urllib.request.Request(
            'https://api.anthropic.com/api/oauth/usage',
            method='GET',
            headers={
                'Authorization': f'Bearer {token}',
                'anthropic-beta': 'oauth-2025-04-20',
                'Content-Type': 'application/json',
                'User-Agent': 'claude-code/2.1.69',
            }
        )
        with urllib.request.urlopen(req, timeout=5) as resp:
            return json.loads(resp.read().decode()), None
    except urllib.error.HTTPError as e:
        retry = None
        try:
            retry = int(e.headers.get('Retry-After', ''))
        except (ValueError, TypeError):
            pass
        return None, retry
    except Exception:
        return None, None


def parse_iso(iso_string):
    """Parse an ISO 8601 datetime string (Python 3.7+ compatible)."""
    try:
        return datetime.fromisoformat(iso_string)
    except (ValueError, AttributeError):
        # Python < 3.11: fromisoformat doesn't handle +HH:MM offsets
        s = re.sub(r'([+-]\d{2}):(\d{2})$', r'\1\2', iso_string)
        fmt = '%Y-%m-%dT%H:%M:%S.%f%z' if '.' in s else '%Y-%m-%dT%H:%M:%S%z'
        return datetime.strptime(s, fmt)


def format_abs_time(dt_local):
    """Format a local datetime as 'Today at 2:59pm', 'Friday at 11:59am', etc."""
    today = datetime.now().date()
    delta_days = (dt_local.date() - today).days
    time_str = dt_local.strftime('%-I:%M') + dt_local.strftime('%p').lower()

    if delta_days == 0:
        return f'Today at {time_str}'
    if delta_days == 1:
        return f'Tomorrow at {time_str}'
    if delta_days < 7:
        return f'{dt_local.strftime("%A")} at {time_str}'
    return f'{dt_local.strftime("%b %-d")} at {time_str}'


def format_reset_time(iso_string):
    """Format ISO timestamp as '2h 15m (Today at 2:59pm)' or '5d 3h (Friday at 11:59am)'."""
    if not iso_string:
        return ''
    try:
        reset_utc = parse_iso(iso_string)
        total_seconds = int((reset_utc - datetime.now(timezone.utc)).total_seconds())
        if total_seconds <= 0:
            return 'now'
        days = total_seconds // 86400
        hours = (total_seconds % 86400) // 3600
        minutes = (total_seconds % 3600) // 60
        if days > 0:
            relative = f'{days}d {hours}h'
        elif hours > 0:
            relative = f'{hours}h {minutes}m'
        else:
            relative = f'{minutes}m'
        reset_local = reset_utc.astimezone()
        return f'{relative} ({format_abs_time(reset_local)})'
    except Exception:
        return ''


WINDOW_HOURS = {
    'five_hour': 5,
    'seven_day': 168,
    'seven_day_sonnet': 168,
}

LIMIT_SHORT_NAMES = {
    'five_hour': 'session',
    'seven_day': 'weekly',
    'seven_day_sonnet': 'sonnet',
}


def limit_projection(key, bucket):
    """Return a warning string if the limit is hit or on pace to be hit, else None."""
    if not bucket:
        return None
    pct = bucket.get('utilization') or 0
    resets_at = bucket.get('resets_at')
    if not resets_at or pct <= 0:
        return None
    window_h = WINDOW_HOURS.get(key)
    if not window_h:
        return None
    try:
        reset_utc = parse_iso(resets_at)
        now = datetime.now(timezone.utc)
        secs_remaining = max(0, (reset_utc - now).total_seconds())
        window_secs = window_h * 3600
        elapsed_secs = window_secs - secs_remaining
        if elapsed_secs <= 0:
            return None
        elapsed_pct = (elapsed_secs / window_secs) * 100
        name = LIMIT_SHORT_NAMES.get(key, key)
        if pct >= 100:
            return (f'  \u26a0 {name} limit hit', True)
        if pct >= elapsed_pct:
            # Project when we'll hit 100% at current rate
            rate = pct / elapsed_secs  # pct per second
            secs_to_100 = (100 - pct) / rate
            hit_time = now + timedelta(seconds=secs_to_100)
            hit_local = hit_time.astimezone()
            return (f'  \u26a0 on pace to hit {name} limit {format_abs_time(hit_local)}', False)
    except Exception:
        pass
    return None


def usage_bar(pct, width=15):
    """Return a text progress bar for the given percentage."""
    filled = round(pct / 100 * width)
    return '\u2588' * filled + '\u2591' * (width - filled)


def usage_color(pct):
    """Return curses color pair number based on usage percentage."""
    if pct >= 80:
        return 4  # red
    if pct >= 50:
        return 3  # yellow
    return 8  # green


def main(stdscr):
    curses.curs_set(0)
    curses.use_default_colors()

    curses.init_pair(1, curses.COLOR_CYAN, -1)                    # header / dividers
    curses.init_pair(2, curses.COLOR_WHITE, -1)                    # normal text
    curses.init_pair(3, curses.COLOR_YELLOW, -1)                   # tab numbers / status
    curses.init_pair(4, curses.COLOR_RED, -1)                      # close confirmation
    curses.init_pair(5, curses.COLOR_BLACK, curses.COLOR_WHITE)    # selected normal
    curses.init_pair(6, curses.COLOR_MAGENTA, -1)                  # claude code tabs
    curses.init_pair(7, curses.COLOR_WHITE, curses.COLOR_MAGENTA)  # selected claude
    curses.init_pair(8, curses.COLOR_GREEN, -1)                    # overwatch badge
    curses.init_pair(9, curses.COLOR_YELLOW, -1)                   # user labels
    stdscr.nodelay(True)
    stdscr.timeout(200)

    last_fetch = 0
    last_usage_fetch = 0
    usage_interval = USAGE_REFRESH_INTERVAL
    tabs = []
    claude_ttys = set()
    usage_data = None
    usage_fetch_ok = True
    selected = 0
    confirm_close = False
    editing_label = False
    label_buffer = ''
    labels = {}  # tty -> label string (does not persist)
    status_msg = ''
    status_time = 0

    while True:
        now = time.time()
        if now - last_fetch >= REFRESH_INTERVAL or last_fetch == 0:
            tabs = fill_missing_paths(fetch_tabs())
            claude_ttys = get_claude_ttys()
            last_fetch = now
            if selected >= len(tabs):
                selected = max(0, len(tabs) - 1)

        # Fetch usage when Claude Code is running (once per minute)
        has_claude = bool(claude_ttys)
        if has_claude and (now - last_usage_fetch >= usage_interval
                          or last_usage_fetch == 0):
            fresh, retry_after = fetch_usage()
            usage_fetch_ok = fresh is not None
            if fresh is not None:
                usage_data = fresh
                usage_interval = USAGE_REFRESH_INTERVAL
            else:
                # Respect server's Retry-After, but never less than normal interval
                usage_interval = max(USAGE_REFRESH_INTERVAL,
                                     retry_after if retry_after else 0)
            last_usage_fetch = now
        elif not has_claude:
            usage_data = None
            usage_fetch_ok = True
            usage_interval = USAGE_REFRESH_INTERVAL
            last_usage_fetch = 0

        stdscr.erase()
        height, width = stdscr.getmaxyx()

        show_usage = usage_data is not None and has_claude
        show_fetch_err = has_claude and not usage_fetch_ok and usage_data is None
        usage_keys = ['five_hour', 'seven_day', 'seven_day_sonnet']
        active_keys = [k for k in usage_keys
                       if usage_data and usage_data.get(k)] if show_usage else []
        # Pre-compute projections once (used for layout and rendering)
        projections = {k: limit_projection(k, usage_data.get(k))
                       for k in active_keys} if show_usage else {}
        warning_count = sum(1 for v in projections.values() if v)
        usage_section = len(active_keys) + warning_count
        if show_fetch_err:
            usage_section += 1  # room for the error line
        bottom_reserved = (3 + usage_section) if usage_section > 0 else 3

        # Header
        title = ' OVERWATCH'
        stdscr.addnstr(0, 0, title, width - 1, curses.color_pair(1) | curses.A_BOLD)
        stdscr.addnstr(1, 0, '\u2500' * min(width - 1, 90), width - 1, curses.color_pair(1))

        # Column headers
        row = 2
        if row < height:
            col_hdr = '          Directory                                       Name'
            stdscr.addnstr(row, 0, col_hdr, width - 1, curses.color_pair(1) | curses.A_DIM)
            row += 1

        # Tab rows
        for i, (win_num, tab_num, path, name, tty) in enumerate(tabs):
            if row >= height - bottom_reserved:
                break
            short = shorten_path(path)
            label = labels.get(tty) if tty else None
            display_name = label or ('overwatch' if tty == MY_TTY else name)
            has_label = bool(label)
            is_selected = (i == selected)
            is_claude = tty in claude_ttys
            is_me = (tty == MY_TTY)

            # Two-column prefix: type badge + tab number
            if is_me:
                badge = ' >> '
            elif is_claude:
                badge = ' CC '
            else:
                badge = '    '
            tab_col = f'{tab_num:>2} '

            # Offsets: badge(4) + tab(3) + gap(2) = 9 before directory
            dir_start = 9
            name_start = dir_start + 49

            # Full line string for selected-row rendering (padded to fill width)
            line = f'{badge}{tab_col}  {short:<48} {display_name}'
            line = line[:width - 1].ljust(width - 1)

            if is_selected and confirm_close:
                stdscr.addnstr(row, 0, line, width - 1, curses.color_pair(4) | curses.A_BOLD)
            elif is_selected and is_claude:
                stdscr.addnstr(row, 0, line, width - 1, curses.color_pair(7) | curses.A_BOLD)
            elif is_selected:
                stdscr.addnstr(row, 0, line, width - 1, curses.color_pair(5) | curses.A_BOLD)
            elif is_me:
                stdscr.addstr(row, 0, badge, curses.color_pair(8) | curses.A_BOLD)
                stdscr.addstr(row, 4, tab_col, curses.color_pair(3))
                stdscr.addnstr(row, dir_start, f'{short:<48}', min(48, width - dir_start), curses.color_pair(2) | curses.A_BOLD)
                if width > name_start:
                    name_color = curses.color_pair(9) | curses.A_BOLD if has_label else curses.color_pair(8)
                    stdscr.addnstr(row, name_start, display_name, width - name_start - 1, name_color)
            elif is_claude:
                stdscr.addstr(row, 0, badge, curses.color_pair(6) | curses.A_BOLD)
                stdscr.addstr(row, 4, tab_col, curses.color_pair(3))
                stdscr.addnstr(row, dir_start, f'{short:<48}', min(48, width - dir_start), curses.color_pair(6))
                if width > name_start:
                    name_color = curses.color_pair(9) | curses.A_BOLD if has_label else curses.color_pair(6)
                    stdscr.addnstr(row, name_start, display_name, width - name_start - 1, name_color)
            else:
                stdscr.addstr(row, 0, badge, curses.A_DIM)
                stdscr.addstr(row, 4, tab_col, curses.color_pair(3))
                stdscr.addnstr(row, dir_start, f'{short:<48}', min(48, width - dir_start), curses.color_pair(2))
                if width > name_start:
                    name_color = curses.color_pair(9) | curses.A_BOLD if has_label else curses.color_pair(2)
                    stdscr.addnstr(row, name_start, display_name, width - name_start - 1, name_color)
            row += 1

        # Bottom section — divider
        divider_row = height - bottom_reserved
        if divider_row > row:
            stdscr.addnstr(divider_row, 0, '\u2500' * min(width - 1, 90), width - 1, curses.color_pair(1))

        # Usage display (when Claude Code is running)
        if show_usage:
            label_map = {'five_hour': 'CC Session Limit',
                         'seven_day': 'CC Weekly Limit ',
                         'seven_day_sonnet': 'CC Sonnet Limit '}
            urow = divider_row
            for key in active_keys:
                bucket = usage_data.get(key) or {}
                urow += 1
                if urow < height - 2:
                    pct = bucket.get('utilization') or 0
                    reset = format_reset_time(bucket.get('resets_at'))
                    bar = usage_bar(pct)
                    color = usage_color(pct)
                    ulabel = label_map[key]

                    stdscr.addstr(urow, 1, ulabel, curses.color_pair(1) | curses.A_BOLD)
                    pct_str = f'{pct:3.0f}%'
                    stdscr.addstr(urow, 19, pct_str, curses.color_pair(color) | curses.A_BOLD)
                    stdscr.addstr(urow, 25, bar, curses.color_pair(color))
                    if reset:
                        stdscr.addstr(urow, 41, f'  resets in {reset}', curses.A_DIM)
                proj = projections.get(key)
                if proj:
                    urow += 1
                    if urow < height - 2:
                        text, is_hit = proj
                        wcolor = 4 if is_hit else 3
                        stdscr.addnstr(urow, 0, text, width - 1,
                                       curses.color_pair(wcolor) | curses.A_BOLD)

        if show_fetch_err:
            err_row = divider_row + 1 + len(active_keys) + warning_count
            if err_row < height - 2:
                stdscr.addstr(err_row, 1, '  usage API fetch failed', curses.A_DIM)

        # Legend
        legend_row = height - 2
        if legend_row > row:
            stdscr.addstr(legend_row, 1, ' CC ', curses.color_pair(6) | curses.A_BOLD)
            stdscr.addstr(legend_row, 6, 'Claude Code', curses.A_DIM)
            stdscr.addstr(legend_row, 20, ' >> ', curses.color_pair(8) | curses.A_BOLD)
            stdscr.addstr(legend_row, 25, 'this tab', curses.A_DIM)

        # Footer
        footer_row = height - 1
        if editing_label:
            prompt = f' Label: {label_buffer}\u2588'
            stdscr.addnstr(footer_row, 0, prompt, width - 1, curses.color_pair(9) | curses.A_BOLD)
        elif confirm_close and tabs:
            _, tab_num, path, name, _ = tabs[selected]
            prompt = f' Close tab {tab_num}? (y/n) '
            stdscr.addnstr(footer_row, 0, prompt, width - 1, curses.color_pair(4) | curses.A_BOLD)
        elif now - status_time < 3 and status_msg:
            stdscr.addnstr(footer_row, 0, f' {status_msg}', width - 1, curses.color_pair(3))
        else:
            controls = [
                ('\u2191\u2193', ' select  '),
                ('enter', ' goto  '),
                ('l', ' label  '),
                ('n', ' new  '),
                ('x', ' close tab  '),
                ('r', ' refresh  '),
                ('q', ' quit'),
            ]
            col = 1
            for key_label, desc in controls:
                if col >= width - 1:
                    break
                stdscr.addstr(footer_row, col, key_label, curses.color_pair(1) | curses.A_BOLD)
                col += len(key_label)
                stdscr.addstr(footer_row, col, desc, curses.A_DIM)
                col += len(desc)

        stdscr.refresh()

        # Key handling
        key = stdscr.getch()

        if editing_label:
            if key == 27:  # Escape
                editing_label = False
            elif key == ord('\n') or key == curses.KEY_ENTER:
                if tabs:
                    _, _, _, _, tty = tabs[selected]
                    if tty:
                        if label_buffer:
                            labels[tty] = label_buffer
                        elif tty in labels:
                            del labels[tty]
                editing_label = False
                label_buffer = ''
            elif key == curses.KEY_BACKSPACE or key == 127:
                label_buffer = label_buffer[:-1]
            elif key != -1 and 32 <= key <= 126:
                label_buffer += chr(key)
            continue

        if confirm_close:
            if key == ord('y') or key == ord('Y'):
                win_num, tab_num, path, name, _ = tabs[selected]
                close_tab(win_num, tab_num)
                confirm_close = False
                status_msg = f'Closed tab {tab_num}'
                status_time = time.time()
                last_fetch = 0
            elif key != -1:
                confirm_close = False
            continue

        if key == ord('q') or key == ord('Q') or key == 27:
            break
        elif key == ord('r') or key == ord('R'):
            last_fetch = 0
            if now - last_usage_fetch >= 10:
                last_usage_fetch = 0
        elif key == curses.KEY_UP:
            selected = max(0, selected - 1)
        elif key == curses.KEY_DOWN:
            selected = min(len(tabs) - 1, selected + 1)
        elif key == ord('x') or key == ord('X'):
            if tabs:
                confirm_close = True
        elif key == ord('l') or key == ord('L'):
            if tabs:
                _, _, _, _, tty = tabs[selected]
                label_buffer = labels.get(tty, '') if tty else ''
                editing_label = True
        elif key == ord('n') or key == ord('N'):
            new_tab()
            status_msg = 'Opened new tab'
            status_time = time.time()
            last_fetch = 0
        elif key == ord('g') or key == ord('G') or key == ord('\n') or key == curses.KEY_ENTER:
            if tabs:
                win_num, tab_num, _, _, _ = tabs[selected]
                goto_tab(win_num, tab_num)
                status_msg = f'Switched to tab {tab_num}'
                status_time = time.time()


if __name__ == '__main__':
    curses.wrapper(main)
